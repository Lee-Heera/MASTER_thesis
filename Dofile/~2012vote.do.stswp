*******************************************
order sido_nm sigungu_nm 
sort sido_nm sigungu_nm 

drop if inlist(sigungu_nm, "청주시상당구", "청주시흥덕구")
drop if inlist(sigungu_nm, "성남시수정구", "성남시중원구", "성남시분당구")
drop if inlist(sigungu_nm, "수원시장안구", "수원시권선구", "수원시팔달구", "수원시영통구")
drop if inlist(sigungu_nm, "창원시의창구", "창원시성산구", "창원시마산합포구", "창원시마산회원구", "창원시진해구")
drop if inlist(sigungu_nm, "안산시상록구", "안산시단원구")
drop if inlist(sigungu_nm, "고양시덕양구", "고양시일산동구", "고양시일산서구")
drop if inlist(sigungu_nm, "용인시수지구", "용인시기흥구", "용인시처인구")
drop if inlist(sigungu_nm, "전주시완산구", "전주시덕진구")
drop if inlist(sigungu_nm, "천안시서북구", "천안시동남구")
drop if inlist(sigungu_nm, "안양시만안구", "안양시동안구")
drop if inlist(sigungu_nm, "부천시오정구", "부천시원미구", "부천시소사구")
drop if inlist(sigungu_nm, "포항시북구", "포항시남구")

replace sigungu_nm="청주시" if sigungu_nm == "청주시(합계)"
replace sigungu_nm="성남시" if sigungu_nm == "성남시(합계)"
replace sigungu_nm="수원시" if sigungu_nm == "수원시(합계)"
replace sigungu_nm="창원시" if sigungu_nm == "창원시(합계)"
replace sigungu_nm="안산시" if sigungu_nm == "안산시(합계)"
replace sigungu_nm="고양시" if sigungu_nm == "고양시(합계)"
replace sigungu_nm="용인시" if sigungu_nm == "용인시(합계)"
replace sigungu_nm="전주시" if sigungu_nm == "전주시(합계)"
replace sigungu_nm="천안시" if sigungu_nm == "천안시(합계)"
replace sigungu_nm="안양시" if sigungu_nm == "안양시(합계)"
replace sigungu_nm="부천시" if sigungu_nm == "부천시(합계)"
replace sigungu_nm="포항시" if sigungu_nm == "포항시(합계)"

gen year = 2012 

save "/Users/ihuila/Desktop/data/master thesis/raw/afterclean/afterdata/vote/2012clean.dta", replace 