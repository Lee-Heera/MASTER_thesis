**********************************************************************
* 21대 국회의원선거 개표결과 2차 클린
* 2020congress_clean.dta → 시군구2 정규화 및 시군구 단위 집계
**********************************************************************
clear all

	global main "/Users/ihuila/Research/MASTER_thesis"
	global data "${main}/Data cleaned"
	global interim "${main}/Data interim"
	global final "${main}/Data final"

******************************************************************************
use "$data/2020congress_clean.dta"
******************************************************************************
* ── 1. 잔여 문자열 컬럼 정리 ────────────────────────────────────────────────
capture confirm variable 선거인수_str
if !_rc {
    destring 선거인수_str 투표수_str, replace ignore(",")
    count if 선거인수_str != 선거인수
    count if 투표수_str   != 투표수
    drop 선거인수_str 투표수_str
}

** 시군구 비어있는 곳 확인
br if 시군구 == ""

* ── 2. 시군구2: 분석 단위 정규화 ────────────────────────────────────────────
*  규칙:
*   (a) 광역시·특별시: 구 단위 그대로 유지
*   (b) 일반 도: A시B구 → A시  (예: 전주시완산구 → 전주시)
*   (c) 창원시: 2020년 코드테이블에 창원시X구로 표기됨 → regex가 창원시로 처리
*       explicit replace 로 명확화
*   (d) 세종특별자치시: 세종특별자치시로 통일

gen 시군구2 = 시군구

* (b) 일반도 A시B구 → A시
gen _광역 = inlist(시도, "서울특별시", "부산광역시", "대구광역시", ///
                   "인천광역시", "광주광역시", "대전광역시", "울산광역시", ///
                   "세종특별자치시")
gen _si_gu = ustrregexm(시군구2, "시.+구$")
replace 시군구2 = ustrregexra(시군구2, "시.+$", "시") if _si_gu & !_광역
drop _광역 _si_gu

* (c) 창원시 구들 (2020년 코드테이블: 창원시X구 형태, regex로 이미 처리되나 명확화)
replace 시군구2 = "창원시" ///
    if 시도 == "경상남도" & ///
       inlist(시군구, "창원시의창구", "창원시성산구", "창원시마산합포구", ///
              "창원시마산회원구", "창원시진해구")

* (d) 세종특별자치시
replace 시군구2 = "세종특별자치시" if 시도 == "세종특별자치시"

label var 시군구2 "시군구 정규화: 광역시·특별시=구, 일반도=시/군, 창원시, 세종"

order 시도 시군구 시군구2 선거구 읍면동 선거인수 투표수
sort 시도 시군구2 선거구 읍면동

/*
** 수동변경
replace 시군구2 = "사천시" if 선거구 == "사천시남해군하동군" & 읍면동 == "벌용동"
replace 시군구2 = "포항시" if 선거구 == "포항시남구울릉군" & inlist(시군구, "남구", "포항시남구")
replace 시군구2 = "포항시" if 선거구 == "포항시북구" & inlist(시군구, "북구", "포항시북구")
*/

******************************************************************************
br
drop 시군구
capture drop 시도_raw 투표구 읍면동_norm
ren 시군구2 시군구

collapse (sum) 선거인수 투표수 더불어민주당 미래통합당 우리공화당 민중당 가자평화인권당 공화당 국민혁명배당금당 국민새정당 민중민주당 한나라당 무소속김용덕 유효투표수 무효투표 기권, by(시도 시군구)

ren (시도 시군구) (sido_nm sigungu_nm)
gen year = 2020 

save "$data/2020congress_clean2.dta", replace
